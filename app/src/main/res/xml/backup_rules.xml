<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- Exclude ALL SharedPreferences (actual files: global_session.xml, user_prefs_<uid>.xml,
         user_prefs_anonymous.xml, feature_flags.xml). Path "." excludes the whole domain. -->
    <exclude domain="sharedpref" path="." />
    <exclude domain="database" path="coachops.db" />
    <exclude domain="file" path="." />
    <exclude domain="external" path="." />
</full-backup-content>
