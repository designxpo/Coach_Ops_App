rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: is the requester the CoachBase admin?
    function isAdmin() {
      return request.auth != null
        && request.auth.token.email == 'priyeshmishraofficial@gmail.com';
    }

    // Admin config — admin writes, any authenticated user reads
    // (coaches read maintenance mode, announcement, remote config on app start)
    match /admin_config/{document} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Notification history — admin only
    match /notifications/{document} {
      allow read, write: if isAdmin();
    }

    // Notification templates — admin only
    match /notification_templates/{templateId} {
      allow read, write: if isAdmin();
    }

    // User records — each user reads/writes their own, admin reads+writes all.
    // The owner may update their own record but CANNOT flip the moderation flag
    // 'suspended' (ban evasion) and cannot delete their record while suspended
    // (delete-then-recreate evasion) — only an admin changes suspension.
    // NOTE: 'plan' and 'role' stay client-writable, so entitlement is
    // client-trusted; a paid-feature bypass is still possible and should be
    // closed with server-side Play purchase verification (Play Developer API).
    match /user_records/{userId} {
      allow read: if request.auth != null
        && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null
        && (request.auth.uid == userId || isAdmin());
      allow update: if isAdmin()
        || (request.auth != null && request.auth.uid == userId
            && !('suspended' in request.resource.data.diff(resource.data).affectedKeys()));
      allow delete: if isAdmin()
        || (request.auth != null && request.auth.uid == userId
            && resource.data.get('suspended', false) != true);
    }

    // Coach data — each coach reads/writes only their own tree
    match /coaches/{coachId} {
      allow read, write: if request.auth != null && request.auth.uid == coachId;

      match /clients/{clientId}           { allow read, write: if request.auth.uid == coachId; }
      match /programs/{programId}         { allow read, write: if request.auth.uid == coachId; }
      match /payments/{paymentId}         { allow read, write: if request.auth.uid == coachId; }
      match /workout_logs/{logId}         { allow read, write: if request.auth.uid == coachId; }
      match /measurements/{measurementId} { allow read, write: if request.auth.uid == coachId; }
      match /notes/{noteId}               { allow read, write: if request.auth.uid == coachId; }
      match /revenue_snapshots/{snapId}   { allow read, write: if request.auth.uid == coachId; }

      // Gym Suite — gym owners manage their gym data under their own tree
      match /gyms/{gymId}                 { allow read, write: if request.auth.uid == coachId; }
      match /gym_members/{memberId}       { allow read, write: if request.auth.uid == coachId; }
      match /gym_plans/{planId}           { allow read, write: if request.auth.uid == coachId; }
      match /gym_payments/{paymentId}     { allow read, write: if request.auth.uid == coachId; }
      match /gym_checkins/{checkinId}     { allow read, write: if request.auth.uid == coachId; }
    }

    // Phone → account directory — members publish their own phone so gym
    // owners/coaches adding them by number link to ONE identity (no duplicates)
    match /user_phone_index/{phone} {
      allow create, update: if request.auth != null
        && request.resource.data.uid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.uid == request.auth.uid;
      allow read: if request.auth != null;
    }

    // Gym membership index — owner writes their members' plan status;
    // members read only their OWN card. Read was world-open, which exposed
    // every gym's full roster (names + phone numbers + plan pricing + UPI id)
    // to any signed-in user. Now scoped to the owner or the linked member.
    // (Members must be linked by memberUid for the in-app card; unlinked
    // phone-only records are visible to their gym owner only.)
    match /gym_memberships/{docId} {
      allow create, update: if request.auth != null
        && request.resource.data.ownerUid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
      allow read: if request.auth != null
        && (resource.data.ownerUid == request.auth.uid
            || resource.data.get('memberUid', '') == request.auth.uid);
    }

    // UPI payment claims — member says "I've paid", gym owner confirms/rejects
    match /gym_payment_claims/{claimId} {
      allow create: if request.auth != null
        && request.resource.data.claimerUid == request.auth.uid;
      allow read, update: if request.auth != null
        && (resource.data.claimerUid == request.auth.uid
            || resource.data.ownerUid == request.auth.uid);
      allow delete: if request.auth != null
        && resource.data.ownerUid == request.auth.uid;
    }

    // In-app issue reports — any signed-in user files their own report;
    // only the admin portal reads/triages them
    match /issue_reports/{reportId} {
      allow create: if request.auth != null
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.message is string
        && request.resource.data.message.size() <= 4000
        && request.resource.data.lastCrash is string
        && request.resource.data.lastCrash.size() <= 6000;
      allow read: if request.auth != null
        && (resource.data.uid == request.auth.uid || isAdmin());
      allow update, delete: if isAdmin();
    }

    // Upgrade requests — user creates/updates their own; admin panel processes
    match /upgrade_requests/{requestId} {
      allow create, update: if request.auth != null
        && (request.resource.data.uid == request.auth.uid || isAdmin());
      allow read: if request.auth != null
        && (resource.data.uid == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // A booking doc (id) exists, belongs to this client, is for this coach,
    // and has actually happened (completed, or confirmed with a past date).
    // This is what makes a rating/review legitimate — not just "I'm signed in".
    function ratableBooking(bid, coachId, clientUid) {
      return exists(/databases/$(database)/documents/bookings/$(bid))
        && get(/databases/$(database)/documents/bookings/$(bid)).data.clientId == clientUid
        && get(/databases/$(database)/documents/bookings/$(bid)).data.coachId == coachId
        && (
          get(/databases/$(database)/documents/bookings/$(bid)).data.status == 'COMPLETED'
          || (get(/databases/$(database)/documents/bookings/$(bid)).data.status == 'CONFIRMED'
              && get(/databases/$(database)/documents/bookings/$(bid)).data.sessionDateMillis > 0
              && get(/databases/$(database)/documents/bookings/$(bid)).data.sessionDateMillis < request.time.toMillis())
        );
    }

    // A rating aggregate change that could only come from ONE new valid rating:
    // count goes up by exactly 1, sum rises by a single 1–5★, nothing decreases,
    // and the displayed average stays in range. Prevents one-shot sabotage
    // (setting a rival to 1.0) or inflation (count = 9999).
    function validRatingBump() {
      return request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['rating', 'ratingSum', 'ratingCount'])
        && request.resource.data.ratingCount == resource.data.get('ratingCount', 0) + 1
        && request.resource.data.ratingSum >= resource.data.get('ratingSum', 0) + 1
        && request.resource.data.ratingSum <= resource.data.get('ratingSum', 0) + 5
        // Displayed average must match the aggregate (±0.1) — stops setting
        // rating to 0.0 (sabotage) or 5.0 while sum/count say otherwise.
        && request.resource.data.rating >= request.resource.data.ratingSum / request.resource.data.ratingCount - 0.1
        && request.resource.data.rating <= request.resource.data.ratingSum / request.resource.data.ratingCount + 0.1;
    }

    // Trainer public profiles — any authenticated user reads; owner writes,
    // admin too (certificate approve/reject sets certStatus). A member may
    // bump ONLY the rating aggregate, and only by one valid star (validRatingBump).
    match /trainers/{trainerId} {
      allow read: if request.auth != null;
      // Owner may write their profile — but NOT self-award a verified badge.
      // certStatus 'verified'/'rejected' are admin-only; the owner may set
      // '', 'pending', or 'verified_auto' (the on-device OCR path, which is
      // client-asserted by design and weaker than admin 'verified').
      allow write: if request.auth != null
        && (isAdmin()
            || (request.auth.uid == trainerId
                && request.resource.data.get('certStatus', '') in ['', 'pending', 'verified_auto']));
      allow update: if request.auth != null
        && request.auth.uid != trainerId          // a coach can't rate themselves
        && validRatingBump();

      // Member reviews — public read; a member may post ONE review per booking
      // and only for a booking they actually completed with this coach. The
      // review doc id IS the booking id, so we can verify the booking directly.
      match /reviews/{reviewId} {
        allow read: if request.auth != null;
        allow create: if request.auth != null
          && request.resource.data.clientId == request.auth.uid
          && request.auth.uid != trainerId
          && request.resource.data.rating >= 1 && request.resource.data.rating <= 5
          && ratableBooking(reviewId, trainerId, request.auth.uid);
        allow update, delete: if isAdmin();   // reviews are immutable once posted
      }
    }

    // Coach → member reliability ratings (aggregate). A coach bumps it after a
    // real completed session; bounded to one valid star so it can't be forged
    // wholesale. (memberId != writer prevents a member self-rating.)
    match /member_ratings/{memberId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null
        && request.auth.uid != memberId
        && request.resource.data.ratingCount == 1
        && request.resource.data.ratingSum >= 1 && request.resource.data.ratingSum <= 5;
      // Same bounded bump as validRatingBump, but the member_ratings doc also
      // carries a 'name' label, so allow that key too.
      allow update: if request.auth != null
        && request.auth.uid != memberId
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['rating', 'ratingSum', 'ratingCount', 'name'])
        && request.resource.data.ratingCount == resource.data.get('ratingCount', 0) + 1
        && request.resource.data.ratingSum >= resource.data.get('ratingSum', 0) + 1
        && request.resource.data.ratingSum <= resource.data.get('ratingSum', 0) + 5
        && request.resource.data.rating >= 0 && request.resource.data.rating <= 5;
      allow delete: if isAdmin();
    }

    // Trainer certificate review queue — coach submits own doc, admin decides
    match /cert_reviews/{trainerId} {
      allow create, update: if request.auth != null
        && (request.auth.uid == trainerId || isAdmin());
      allow read: if request.auth != null
        && (request.auth.uid == trainerId || isAdmin());
      allow delete: if isAdmin();
    }

    // Bookings. Create only as yourself and only PENDING (you can't self-confirm
    // a booking into a ratable state). Reads limited to the two parties.
    // Updates are field-scoped by role: the COACH drives status/response/
    // coachRating; the CLIENT may only cancel or write their own rating fields —
    // crucially a client CANNOT move their own booking to CONFIRMED/COMPLETED,
    // which previously let them forge a ratable session and fake reviews.
    match /bookings/{bookingId} {
      allow create: if request.auth != null
        && request.resource.data.clientId == request.auth.uid
        && request.resource.data.status == 'PENDING';
      allow read: if request.auth != null
        && (resource.data.coachId == request.auth.uid
            || resource.data.clientId == request.auth.uid);
      allow update: if request.auth != null && (
        // Coach: status transitions, response, rating the member back
        (resource.data.coachId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['status', 'coachResponse', 'coachRating', 'cancelledAt']))
        ||
        // Client: submit their own rating/review
        (resource.data.clientId == request.auth.uid
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['clientRating', 'clientReview']))
        ||
        // Client: cancel their own booking (never to a ratable status)
        (resource.data.clientId == request.auth.uid
          && request.resource.data.status == 'CANCELLED'
          && request.resource.data.diff(resource.data).affectedKeys()
               .hasOnly(['status', 'coachResponse', 'cancelledAt']))
      );
    }

    // Personal health tracking (steps, water, sleep, mood, measurements,
    // progress photos, cycle) — owner only. THIS RULE WAS MISSING: every
    // health write was server-denied, which crashed the app on water taps,
    // mood ratings and the 50-step auto-save.
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      match /{healthCollection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }

    // Coach → member diet plans
    match /diet_plans/{planId} {
      allow create, update: if request.auth != null
        && request.resource.data.coachUid == request.auth.uid;
      allow delete: if request.auth != null
        && resource.data.coachUid == request.auth.uid;
      allow read: if request.auth != null
        && (resource.data.coachUid == request.auth.uid
            || resource.data.clientId == request.auth.uid);
    }

    // Diet adherence logs — member creates, both parties read/update.
    // Read is scoped to the two parties (was auth-wide "because logs are
    // queried by unguessable planId" — obscurity, not security; a
    // collection-wide read exposed every member's adherence % and notes).
    match /diet_logs/{logId} {
      allow create: if request.auth != null
        && request.resource.data.clientId == request.auth.uid;
      allow update: if request.auth != null
        && (resource.data.clientId == request.auth.uid
            || resource.data.coachUid == request.auth.uid);
      allow read: if request.auth != null
        && (resource.data.clientId == request.auth.uid
            || resource.data.coachUid == request.auth.uid);
    }

    // Nutrition plan content published from the admin panel
    match /nutrition_plans/{goal} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Client fitness data — only the owner can read/write
    match /client_fitness/{clientId} {
      allow read, write: if request.auth != null && request.auth.uid == clientId;

      match /goals/{goalId}       { allow read, write: if request.auth.uid == clientId; }
      match /logs/{logId}         { allow read, write: if request.auth.uid == clientId; }
      match /food_diary/{entryId} { allow read, write: if request.auth.uid == clientId; }
    }

    // Direct chat between coach and member.
    // chatId = "{coachId}_{memberId}"; Firebase Auth UIDs never contain '_',
    // so splitting the id yields exactly the two participant uids. Gating on
    // membership keeps message CONTENT private — previously any authenticated
    // user could read any chat (coach uids are public via /trainers).
    // App queries still pass: coaches query where coachId==me and members
    // where memberId==me, so every returned doc has the requester in its id.
    match /chats/{chatId} {
      allow read, create, update: if request.auth != null
        && request.auth.uid in chatId.split('_');

      match /messages/{messageId} {
        allow read, create, update: if request.auth != null
          && request.auth.uid in chatId.split('_');
        allow delete: if false;
      }
    }

    // Member health records — OWNER ONLY. Previously any authenticated user
    // could read any member's weight/body-fat/health history ("coach context
    // enforced in UI"), but no screen actually reads another member's records
    // (getMemberRecords is dead code), so open read was pure exposure. If a
    // coach-views-client-health feature is added later, gate it on an explicit
    // coach↔member connection doc, not a blanket read.
    match /member_health/{memberId} {
      allow read, write: if request.auth != null && request.auth.uid == memberId;

      match /records/{recordId} {
        allow read, write: if request.auth != null && request.auth.uid == memberId;
      }
    }

    // Exercise library — any authenticated user reads, admin-only writes
    match /exercises/{exerciseId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Early access sign-ups — public create (unauthenticated website visitors), admin read/delete
    match /early_access/{docId} {
      allow create: if request.resource.data.keys().hasAll(['name', 'email', 'role', 'signedUpAt'])
        && request.resource.data.name is string && request.resource.data.name.size() <= 100
        && request.resource.data.email is string && request.resource.data.email.size() <= 200
        && request.resource.data.role in ['coach', 'member', 'gym_owner'];
      allow read, delete: if isAdmin();
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
